  },
  "yara": {
    "enabled": false,
    "rules_path": ""
  },
  "capa": {
    "enabled": false,
    "exe_path": "capa",
    "rules_path": ""
  },
  "viper": {
    "enabled": false,
    "exe_path": "viper-cli",
    "project_name": "default"
  },
